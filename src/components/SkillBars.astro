---
// A titled section of labelled progress bars (languages / expertise / programming).
// Bar widths are literal millimetres straight from the YAML, exactly as before.
import type { CvData } from "../lib/cv";
const { title, items, config } = Astro.props as {
  title?: string;
  items: Record<string, number>;
  config: CvData["config"];
};
const max = Number(config.sidebar_width) - 2 * Number(config.padding);
---

<h3>{title}</h3>
<div class="skill-container">
  {Object.entries(items).map(([name, value]) => (
    <>
      <p style="margin-bottom: 0">{name}</p>
      <div class="bar-container">
        <div class="bar-blue" style={`width: ${value}mm`}></div>
        <div class="bar-grey" style={`width: ${max - value}mm`}></div>
      </div>
      <div class="skill-spacer"></div>
    </>
  ))}
</div>
